@model UM_with_Role_Claim_Audit_log.Models.ViewModels.ResetPasswordViewModel

@{
    // Set the page title for browser tab and navigation breadcrumb
    ViewData["Title"] = "Reset Password";
}

<!-- Main Container: Reset Password Form Page -->
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <!-- Card: Password Reset Interface -->
            <!-- Yellow header indicates caution/warning for password change -->
            <div class="card shadow-sm">

                <!-- Card Header: Yellow background for password security operation -->
                <div class="card-header bg-warning">
                    <h4 class="mb-0">Reset Password</h4>
                </div>

                <div class="card-body">

                    <!-- Info Alert: Shows which user's password is being reset -->
                    <!-- Helps admin confirm they're resetting the correct account -->
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        Resetting password for: <strong>@Model.Email</strong>
                    </div>

                    <!-- Form: Submit new password to server -->
                    <!-- Posts to UsersController.ResetPassword action method -->
                    <form asp-action="ResetPassword" method="post">

                        @* Anti-Forgery Token: CSRF protection for secure form submission *@
                        @Html.AntiForgeryToken()

                        @* Hidden Fields: Pass user identification to controller *@
                        @* Required to identify which user's password to reset *@
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Email" />

                        @* Validation Summary: Display model-level validation errors *@
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- New Password Field: Enter new password for the user -->
                        <!-- Validation: Required, minimum length, complexity requirements -->
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label"></label>
                            <input asp-for="NewPassword" class="form-control" />
                            @* Field-level validation: Shows password-specific errors *@
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <!-- Confirm Password Field: Re-enter password to prevent typos -->
                        <!-- Validation: Must match NewPassword field -->
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            @* Field-level validation: Shows confirmation mismatch errors *@
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <!-- Form Actions: Reset and Cancel buttons -->
                        <div class="d-flex gap-2">

                            <!-- Reset Password Button: Submit form and change password -->
                            <!-- This will: -->
                            <!-- - Validate password strength -->
                            <!-- - Update user's password hash -->
                            <!-- - Log password change in audit log -->
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-key"></i> Reset Password
                            </button>

                            <!-- Cancel Button: Return to Users Index without resetting -->
                            <!-- Allows admin to abort the password reset operation safely -->
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* Validation Scripts: Client-side validation using jQuery Validate *@
    @* Provides instant feedback before form submission *@
    @* Validates: Required fields, password complexity, password match *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <!-- Bootstrap Icons CDN: Provides icon fonts for key and back icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}