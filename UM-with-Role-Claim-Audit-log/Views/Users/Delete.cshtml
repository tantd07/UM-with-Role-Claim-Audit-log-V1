@model UM_with_Role_Claim_Audit_log.Models.ViewModels.UserViewModel

@{
    // Set the page title for browser tab and navigation breadcrumb
    ViewData["Title"] = "Delete User";
}

<!-- Main Container: Delete User Confirmation Page -->
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <!-- Card: User Deletion Confirmation Interface -->
            <!-- Red border styling to emphasize the destructive nature of this action -->
            <div class="card shadow-sm border-danger">

                <!-- Card Header: Red background to warn about dangerous operation -->
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Delete User</h4>
                </div>

                <div class="card-body">

                    <!-- Warning Alert: Primary confirmation message -->
                    <!-- Warns that deletion is permanent and cannot be reversed -->
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this user? This action cannot be undone.
                    </div>

                    <!-- User Details: Display information about the user being deleted -->
                    <!-- Helps admin verify they're deleting the correct account -->
                    <dl class="row">

                        <!-- Email: User's email address (also used as login username) -->
                        <dt class="col-sm-3">Email</dt>
                        <dd class="col-sm-9">@Model.Email</dd>

                        <!-- Username: Display name for the user account -->
                        <!-- In most cases, this matches the email address -->
                        <dt class="col-sm-3">Username</dt>
                        <dd class="col-sm-9">@Model.UserName</dd>

                        <!-- Roles: Display all roles assigned to this user -->
                        <!-- Shows what permissions will be lost when user is deleted -->
                        <dt class="col-sm-3">Roles</dt>
                        <dd class="col-sm-9">
                            @* Conditional Display: Show roles if any exist, otherwise show empty state *@
                            @if (Model.Roles.Any())
                            {
                                @* Join multiple roles with comma separator *@
                                @* Example: "Admin, Manager" or "Customer" *@
                                @string.Join(", ", Model.Roles)
                            }
                            else
                            {
                                <!-- Empty State: User has no assigned roles -->
                                <span class="text-muted">No roles</span>
                            }
                        </dd>
                    </dl>

                    <!-- Form: Submit user deletion request to server -->
                    <!-- Posts to UsersController.Delete action method -->
                    <form asp-action="Delete" method="post">

                        @* Anti-Forgery Token: CSRF protection for secure form submission *@
                        @Html.AntiForgeryToken()

                        @* Hidden Field: Pass user ID to controller for deletion *@
                        @* Required to identify which user account to delete *@
                        <input type="hidden" asp-for="Id" />

                        <!-- Form Actions: Delete and Cancel buttons -->
                        <div class="d-flex gap-2">

                            <!-- Delete Button: Confirm and execute user deletion -->
                            <!-- Red styling emphasizes the destructive nature of this action -->
                            <!-- This will: -->
                            <!-- - Remove user from AspNetUsers table -->
                            <!-- - Remove all associated user roles -->
                            <!-- - Remove all user-specific claims -->
                            <!-- - Log the deletion in audit log -->
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </button>

                            <!-- Cancel Button: Return to Users Index without deleting -->
                            <!-- Allows admin to abort the deletion operation safely -->
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Bootstrap Icons CDN: Provides icon fonts for warning and action icons -->
    <!-- Used for exclamation-triangle (warning), trash (delete), and arrow-left (cancel) icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
}