  "ConnectionStrings": {
    // Local SQL Server Database Connection
    // FOR PRODUCTION: Replace with your actual database server and credentials
    // Supported: SQL Server, Azure SQL, SQL Express
    // Example Production: "Server=your-server.database.windows.net;Database=YourDB;User Id=admin;Password=YourPassword;"
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=UserManagementDB;Trusted_Connection=True;MultipleActiveResultSets=true"
  },

  "Logging": {
    // Logging Configuration for Application Monitoring
    // Adjust log levels based on your environment (Development/Production)
    "LogLevel": {
      // Default log level for all categories
      // Options: Trace, Debug, Information, Warning, Error, Critical, None
      "Default": "Information",

      // ASP.NET Core framework logs - set to Warning to reduce noise
      // Change to "Information" or "Debug" for troubleshooting
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Allowed Hosts Configuration
  // "*" allows all hosts (suitable for development)
  // FOR PRODUCTION: Specify your domain(s) for security
  // Example: "AllowedHosts": "yourdomain.com;www.yourdomain.com"
  "AllowedHosts": "*"

